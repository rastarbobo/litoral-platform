    "@types/ms": "2.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vinext/cloudflare": "^0.1.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.27",
    "drizzle-kit": "^0.31.10",
