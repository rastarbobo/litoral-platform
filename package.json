{
  "name": "cloudflare-workers-nextjs-saas-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "rm -rf node_modules/.vite .vinext/cache dist vinext worker worker-dist && vinext build --verbose",
    "analyze:bundle": "ANALYZE_BUNDLE=1 pnpm build",
    "build:prod": "vinext deploy --dry-run",
    "start": "vinext start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "check:vinext": "vinext check",
    "typecheck": "tsc --noEmit",
    "deploy": "vinext deploy",
    "deploy:all": "pwsh ./scripts/pi-tools/deploy.ps1 -Force",
    "preview": "pnpm build && wrangler dev --local ${WRANGLER_DEV_ARGS:-}",
    "deploy:dryrun": "rm -rf worker-dist && pnpm build && wrangler deploy --outdir worker-dist --dry-run",
    "cf-typegen": "wrangler types --env-file .env.example",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate:dev": "echo yes | wrangler d1 migrations apply $(node scripts/get-db-name.mjs) --local",
    "reset": "rm -rf .wrangler && pnpm db:migrate:dev && pnpm db:seed",
    "db:seed": "wrangler d1 execute $(node scripts/get-db-name.mjs) --local --file=./src/db/seed.sql",
    "postinstall": "pnpm run cf-typegen"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@base-ui/react": "^1.5.0",
    "@floating-ui/react": "^0.27.16",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@marsidev/react-turnstile": "^1.5.2",
    "@oslojs/encoding": "^1.1.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^6.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^3.13.0",
    "@tiptap/extension-code-block-lowlight": "^3.13.0",
    "@tiptap/extension-highlight": "^3.13.0",
    "@tiptap/extension-horizontal-rule": "^3.13.0",
    "@tiptap/extension-image": "^3.13.0",
    "@tiptap/extension-list": "^3.13.0",
    "@tiptap/extension-subscript": "^3.13.0",
    "@tiptap/extension-superscript": "^3.13.0",
    "@tiptap/extension-table": "^3.13.0",
    "@tiptap/extension-text-align": "^3.13.0",
    "@tiptap/extension-typography": "^3.13.0",
    "@tiptap/extensions": "^3.13.0",
    "@tiptap/markdown": "^3.13.0",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@tiptap/static-renderer": "^3.13.0",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "file-type": "^21.1.1",
    "highlight.js": "~11.11.1",
    "image-size": "^2.0.2",
    "ipaddr.js": "^2.2.0",
    "lodash.throttle": "^4.1.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "ms": "^2.1.3",
    "next": "16.2.6",
    "next-safe-action": "^8.5.2",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.8.16",
    "nuqs": "^2.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "react-hotkeys-hook": "^5.2.1",
    "remeda": "^2.22.1",
    "server-only": "^0.0.1",
    "slugify": "^1.6.6",
